generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Player {
  id           String  @id @default(uuid())
  name         String  @unique
  apiToken     String
  avatarUrl    String?
  dreambornUrl String?
  games        Game[]
}

model Game {
  id String @id

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  startedAt DateTime
  queueId   String?
  wentFirst Boolean?

  result    String
  endReason String
  myLore    Int
  oppLore   Int
  mmrBefore Int?
  mmrAfter  Int?
  mmrDelta  Int?

  myDeckColors   String?
  yourDecklist   String?
  oppDisplayName String
  oppDeckColors  String?
  replayUrl      String?

  createdAt DateTime @default(now())

  @@index([queueId])
  @@index([startedAt(sort: Desc)])
  @@index([playerId])
}

model QueueConfig {
  id       String  @id
  isActive Boolean @default(true)
}
